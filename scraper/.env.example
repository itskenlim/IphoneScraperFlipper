# IAASE scraper — template for all tuned knobs (safe to commit; no secrets).
# Loaded from scraper/ (see scraper/scraper/env.mjs).
#
# First-time setup:
#   cp scraper/.env.example scraper/.env
#   # Fill SUPABASE_* and any tokens below.
#
# After wiping .env, restore your working copy (includes secrets, gitignored):
#   bash scripts/restore_env.sh
#
# After changing scraper/.env or web/.env.local, refresh local backups:
#   bash scripts/snapshot_env.sh

# =============================================================================
# Required
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Full Facebook Marketplace search URL (must be https://www.facebook.com/...)
FB_MARKETPLACE_ILOILO_URL=https://www.facebook.com/marketplace/iloilo/search?query=iphone

# Persistent browser profile (Facebook session lives here)
PLAYWRIGHT_PROFILE_DIR=.playwright_profile/default

# =============================================================================
# Browser
# =============================================================================
PLAYWRIGHT_BROWSER_CHANNEL=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_EXTRA_USE_STEALTH=true
PLAYWRIGHT_PROFILE_ISOLATE_BY_CHANNEL=true

# Optional: separate profiles per job (discover vs monitor)
PLAYWRIGHT_PROFILE_DIR_DISCOVER=.playwright_profile/fb_account_a
PLAYWRIGHT_PROFILE_DIR_MONITOR=.playwright_profile/fb_account_b

# =============================================================================
# Per-run limits (read by run_discover.sh / run_monitor.sh)
# =============================================================================
DISCOVER_MAX_CARDS=50
MONITOR_LIMIT=50

# =============================================================================
# Discovery throughput & filters
# =============================================================================
PLAYWRIGHT_DISCOVERY_ENRICH_ENABLED=true
PLAYWRIGHT_DISCOVERY_ENRICH_CONCURRENCY=2
PLAYWRIGHT_DISCOVERY_ENRICH_CHUNK_SIZE=20
PLAYWRIGHT_DISCOVERY_ENRICH_BLOCK_IMAGES=true
PLAYWRIGHT_DISCOVERY_FEED_BLOCK_IMAGES=true
PLAYWRIGHT_DISCOVERY_MIN_PRICE_PHP=5000
PLAYWRIGHT_DISCOVERY_FILTER_BUYERS=true
PLAYWRIGHT_DISCOVERY_REQUIRE_IPHONE_MODEL=false
PLAYWRIGHT_DISCOVERY_UPDATE_EXISTING_GRAPHQL=false
PLAYWRIGHT_DISCOVERY_GRAPHQL_ONLY=false
# Comma-separated keywords to exclude (optional)
# PLAYWRIGHT_DISCOVERY_EXCLUDE_KEYWORDS=

# =============================================================================
# Monitor / watchlist
# =============================================================================
PLAYWRIGHT_WATCHLIST_RECHECK_LIMIT=8
PLAYWRIGHT_WATCHLIST_RECHECK_CONCURRENCY=1
PLAYWRIGHT_WATCHLIST_CHUNK_SIZE=20
PLAYWRIGHT_WATCHLIST_SKIP_BUYERS=true
PLAYWRIGHT_MONITOR_BLOCK_IMAGES=true
PLAYWRIGHT_MONITOR_WAIT_FOR_NETWORKIDLE=false
PLAYWRIGHT_MONITOR_GRAPHQL_ONLY=false
PLAYWRIGHT_MONITOR_EMBED_FALLBACK=true
PLAYWRIGHT_MONITOR_STATUS_FALLBACK=true
# desc = embed price/status every run; DOM description only when missing or stale (see DESC_REFRESH_HOURS)
PLAYWRIGHT_MONITOR_DOM_MODE=desc
PLAYWRIGHT_MONITOR_DESC_REFRESH_HOURS=48
PLAYWRIGHT_MONITOR_USE_NETWORK=true

# Tiered monitor scheduling (see docs/MONITOR_SCHEDULING.md)
# tiered = due-date queue by deal score + age | legacy = old last_seen_at round-robin
PLAYWRIGHT_MONITOR_SCHEDULER=tiered
PLAYWRIGHT_MONITOR_HOT_MAX_AGE_DAYS=3
PLAYWRIGHT_MONITOR_WARM_MAX_AGE_DAYS=7
PLAYWRIGHT_MONITOR_HOT_INTERVAL_HOURS=6
PLAYWRIGHT_MONITOR_WARM_INTERVAL_HOURS=24
PLAYWRIGHT_MONITOR_COLD_INTERVAL_HOURS=168
PLAYWRIGHT_MONITOR_PRICE_CHANGE_HOT_HOURS=48
PLAYWRIGHT_MONITOR_COLD_STALE_PRICE_DAYS=7
PLAYWRIGHT_MONITOR_FAIL_LOCKOUT_BASE_MINUTES=5
PLAYWRIGHT_MONITOR_FAIL_LOCKOUT_MAX_MINUTES=120
PLAYWRIGHT_MONITOR_FETCH_POOL_MULTIPLIER=3

# =============================================================================
# Scrape timing & network
# =============================================================================
SCRAPE_GOTO_RETRY_COUNT=2
SCRAPE_DELAY_MIN_MS=0
SCRAPE_DELAY_MAX_MS=0
SCRAPE_USE_NETWORK=true
SCRAPE_NETWORK_SAVE_RAW=false
SCRAPE_SCROLL_PAGES=3
SCRAPE_SCROLL_DELAY_MS=1200
SCRAPE_FEED_SELECTOR_TIMEOUT_MS=60000
SCRAPE_NETWORK_POKE_COUNT=2
SCRAPE_NETWORK_POKE_WAIT_MS=1200
SCRAPE_NETWORK_FINAL_WAIT_MS=800
SCRAPE_NETWORK_RELOAD_WAIT_MS=1200
# SCRAPE_MONITOR_NETWORK_POKE_COUNT=
# SCRAPE_MONITOR_NETWORK_POKE_WAIT_MS=
# Prefer embed/network structured price (listing_price_amount/formatted) over DOM above-fold parsing.
# Name says "graphql" for legacy reasons — applies to embedded JSON too, not just live GraphQL capture.
PLAYWRIGHT_PREFER_GRAPHQL_PRICE_RAW=true

# =============================================================================
# Database writes
# =============================================================================
DB_RETRY_COUNT=5
DB_RETRY_BASE_MS=2000
DB_BATCH_SIZE=25
DB_LOG_CHANGES=false
DB_LOG_CHANGE_LIMIT=25

# =============================================================================
# Automation (timers / overlap / login cooldown)
# =============================================================================
SCRAPE_RUN_JITTER_MAX_S=60
SCRAPE_MONITOR_START_DELAY_S=15
SCRAPE_GLOBAL_LOCK_WAIT_S=7200
LOGIN_REQUIRED_COOLDOWN_MINUTES=180

# =============================================================================
# Deals compute (compute_deals.mjs)
# =============================================================================
DEALS_MAX_LISTINGS=5000
# DEALS_DEBUG_LISTING_ID=

# =============================================================================
# Telegram alerts (login required)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# =============================================================================
# Engine selector (default: playwright-extra)
# =============================================================================
# SNIFFER_ENGINE=playwright-extra

# =============================================================================
# Debug (leave off in production)
# =============================================================================
# SCRAPE_LOG_PROGRESS=true
# SCRAPE_LOG_FILE=true
# SCRAPE_NETWORK_DEBUG=false
# SCRAPE_NETWORK_DEBUG_ALL=false
# SCRAPE_DEBUG_DESC=false
# SCRAPE_DEBUG_DESC_ALL=false
# SCRAPE_DEBUG_STATUS=false
# SCRAPE_DEBUG_STATUS_TEXT=false
# SCRAPE_DEBUG_NETWORK_KEYS=false
# SCRAPE_DEBUG_EMBED_KEYS=false
# DOTENV_DEBUG=1
