# IAASE web dashboard — server-only template (safe to commit; no secrets).
#
# First-time setup:
#   cp web/.env.example web/.env.local
#   # Fill SUPABASE_* and WEB_AUTH_* below.
#
# After wiping .env.local, restore from gitignored backup:
#   bash scripts/restore_env.sh

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Shared password for /login
WEB_AUTH_PASSWORD=change_me

# Random secret for signing the session cookie (e.g. `openssl rand -hex 32`)
WEB_AUTH_SECRET=generate_with_openssl_rand_hex_32

# Optional cookie name override
# WEB_AUTH_COOKIE_NAME=iaase_session
